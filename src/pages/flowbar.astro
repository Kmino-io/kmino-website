---
import FlowbarLayout from "../layouts/FlowbarLayout.astro";
---

<FlowbarLayout>
  <div class="taglines">
    <span>macOS-native</span>
    <span>define tasks</span>
    <span>check them complete</span>
    <span>set timers for focus periods</span>
  </div>
</FlowbarLayout>

<style>
  .taglines {
    position: absolute;
    bottom: clamp(32px, 5.5vw, 80px);
    right: clamp(24px, 5.5vw, 80px);
    display: flex;
    flex-direction: column;
    gap: 7px;
    color: #f5f0e8;
    font-family: Helvetica, Arial, sans-serif;
    font-weight: 300;
    font-size: clamp(12px, 1.25vw, 18px);
    line-height: 1.1;
    letter-spacing: 0.31em;
    text-align: right;
    pointer-events: none;
  }
</style>
