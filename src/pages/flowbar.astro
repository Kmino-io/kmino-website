---
import { Image } from "astro:assets";
import bg1 from "../assets/flowbar/bg1.webp";
import bg2 from "../assets/flowbar/bg2.webp";
import bg4 from "../assets/flowbar/bg4.webp";
import bg5 from "../assets/flowbar/bg5.webp";
import AppStoreDownloadButton from "../assets/flowbar/appstore-download.svg";
import FlowbarLogo from "../assets/flowbar/flowbar.svg";
import FlowbarIcon from "../assets/flowbar/flowbar-icon.svg";

const downloadLink = "add link here";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Flowbar — macOS task & focus timer</title>
    <meta
      name="description"
      content="macOS-native app to define tasks, check them complete, and set timers for focus periods."
    />
    <link rel="icon" type="image/svg+xml" href="/flowbar-icon.svg" />
    <meta property="og:title" content="Flowbar" />
    <meta
      property="og:description"
      content="macOS-native. Define tasks, check them complete, set timers for focus periods."
    />
    <meta name="theme-color" content="#c4b96e" />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html,
      body {
        width: 100%;
        height: 100%;
        overflow: visible;
      }

      .slide {
        position: fixed;
        inset: 0;
        background-size: cover;
        background-position: center;
        opacity: 0;
        transition: opacity 1s ease-in-out;
      }

      .slide.active {
        opacity: 1;
      }

      .ui-layer {
        position: fixed;
        inset: 0;
        z-index: 100;
        display: flex;
        justify-content: center;
        pointer-events: none;
      }

      .ui-container {
        width: 100%;
        max-width: 1440px;
        position: relative;
        pointer-events: none;
      }

      .menu-btn {
        position: absolute;
        top: clamp(32px, 5.5vw, 80px);
        right: clamp(24px, 5.5vw, 80px);
        pointer-events: auto;
        display: flex;
        align-items: center;
        gap: 20px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        color: #f5f0e8;
        font-family: Helvetica, Arial, sans-serif;
        font-weight: 300;
        font-size: clamp(14px, 1.4vw, 20px);
        line-height: 1.1;
        letter-spacing: 0.31em;
        text-transform: lowercase;
      }

      .menu-icon {
        display: flex;
        flex-direction: column;
        gap: 6px;
      }

      .menu-icon span {
        display: block;
        height: 1.5px;
        background: #f5f0e8;
        border-radius: 1px;
      }

      .menu-icon span:nth-child(1) {
        width: 36px;
      }
      .menu-icon span:nth-child(2) {
        width: 28px;
        align-self: flex-end;
      }
      .menu-icon span:nth-child(3) {
        width: 36px;
      }

      .download-btn {
        background-color: rgba(255, 255, 255, 0.8);
        border-radius: 7px;
        width: clamp(100px, 9vw, 127px);
        height: auto;
        pointer-events: auto;
      }

      .hero a {
        pointer-events: auto;
      }

      .hero {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: fit-content;
        gap: clamp(20px, 2.5vw, 34px);
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
      }

      @media (min-width: 768px) {
        .hero {
          left: clamp(24px, 5.5vw, 80px);
          transform: translateY(-50%);
        }
      }

      .taglines {
        position: absolute;
        bottom: clamp(32px, 5.5vw, 80px);
        right: clamp(24px, 5.5vw, 80px);
        display: flex;
        flex-direction: column;
        gap: 7px;
        color: #f5f0e8;
        font-family: Helvetica, Arial, sans-serif;
        font-weight: 300;
        font-size: clamp(12px, 1.25vw, 18px);
        line-height: 1.1;
        letter-spacing: 0.31em;
        text-align: right;
      }

      /* Menu overlay — backdrop only */
      .menu-overlay {
        position: fixed;
        inset: 0;
        z-index: 200;
        pointer-events: none;
      }

      .menu-panel {
        position: fixed;
        top: 0;
        bottom: 0;
        right: 0;
        width: min(480px, 100vw);
        background: #ccbb65;
        display: flex;
        flex-direction: column;
        /*justify-content: space-between;*/
        padding: clamp(32px, 5vw, 80px);
        transform: translateX(100%);
        transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        pointer-events: none;
        z-index: 201;
      }

      .menu-overlay.open {
        pointer-events: auto;
      }

      .menu-panel.open {
        transform: translateX(0);
        pointer-events: auto;
      }

      .menu-panel-header {
        display: flex;
        align-items: center;
        margin-bottom: 44px;
        justify-content: space-between;
      }

      .menu-panel-title {
        color: #f5f0e8;
        font-family: Helvetica, Arial, sans-serif;
        font-weight: 300;
        font-size: clamp(16px, 1.4vw, 20px);
        letter-spacing: 0.31em;
        line-height: 1.1;
      }

      .fb-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10.67px;
        height: 44px;
        padding: 5.33px 10.67px;
        border-radius: 16px;
        border: 1.33px solid #a7a092;
        background: #ffffff;
        color: #1a1a1a;
        box-shadow: 2.67px 2.67px 0 0 #dcd468;
        cursor: pointer;
        font-family: Helvetica, Arial, sans-serif;
        font-weight: 300;
        font-size: 16px;
        letter-spacing: 0.05em;
        flex-shrink: 0;
      }

      .menu-close-btn {
        width: 44px;
        padding: 0;
        font-size: 20px;
        line-height: 1;
      }

      .menu-nav {
        display: flex;
        flex-direction: column;
        gap: clamp(24px, 4vw, 40px);
      }

      .menu-nav a {
        color: #f5f0e8;
        text-decoration: none;
        font-family: Helvetica, Arial, sans-serif;
        font-weight: 300;
        font-size: 20px;
        line-height: 1.1;
        letter-spacing: 0.31em;
        transition: opacity 0.2s;
      }

      .menu-nav a:hover {
        opacity: 0.6;
      }

      .menu-panel-footer {
        display: flex;
        justify-content: center;
        margin-top: auto;
      }
    </style>
  </head>
  <body>
    <div class="ui-layer">
      <div class="ui-container">
        <div class="hero">
          <FlowbarLogo />
          <a href={downloadLink} target="_blank">
            <AppStoreDownloadButton class="download-btn" />
          </a>
        </div>

        <div class="taglines">
          <span>macOS-native</span>
          <span>define tasks</span>
          <span>check them complete</span>
          <span>set timers for focus periods</span>
        </div>

        <button class="menu-btn" id="menu-open-btn" aria-label="Open menu">
          <span>menu</span>
          <div class="menu-icon" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>
        </button>
      </div>
    </div>

    <div class="menu-overlay" id="menu-overlay">
      <div class="menu-panel" id="menu-panel">
        <div class="menu-panel-header">
          <span class="menu-panel-title">menu</span>
          <button
            class="fb-btn menu-close-btn"
            id="menu-close-btn"
            aria-label="Close menu"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 14 14"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <line
                x1="1"
                y1="1"
                x2="13"
                y2="13"
                stroke="#1a1a1a"
                stroke-width="1.5"
                stroke-linecap="round"></line>
              <line
                x1="13"
                y1="1"
                x2="1"
                y2="13"
                stroke="#1a1a1a"
                stroke-width="1.5"
                stroke-linecap="round"></line>
            </svg>
          </button>
        </div>

        <nav class="menu-nav">
          <a href="/flowbar">home</a>
          <a href="/flowbar/support">support</a>
          <a href="/flowbar/privacy-policy">privacy policy</a>
          <a href={downloadLink} target="_blank">download flowbar</a>
        </nav>

        <div class="menu-panel-footer">
          <div class="menu-app-icon">
            <FlowbarIcon />
          </div>
        </div>
      </div>
    </div>

    <div class="slide active" style={`background-image: url(${bg1.src})`}></div>
    <div class="slide" style={`background-image: url(${bg2.src})`}></div>
    <div class="slide" style={`background-image: url(${bg4.src})`}></div>
    <div class="slide" style={`background-image: url(${bg5.src})`}></div>

    <script is:inline>
      // Slideshow
      var slides = document.querySelectorAll(".slide");
      var current = 0;
      setInterval(function () {
        slides[current].classList.remove("active");
        current = (current + 1) % slides.length;
        slides[current].classList.add("active");
      }, 3000);

      // Menu
      var overlay = document.getElementById("menu-overlay");
      var panel = document.getElementById("menu-panel");
      var openBtn = document.getElementById("menu-open-btn");
      var closeBtn = document.getElementById("menu-close-btn");

      function openMenu() {
        overlay.classList.add("open");
        panel.classList.add("open");
      }
      function closeMenu() {
        overlay.classList.remove("open");
        panel.classList.remove("open");
      }

      openBtn.addEventListener("mouseenter", openMenu);
      openBtn.addEventListener("click", openMenu);
      openBtn.addEventListener("touchstart", function (e) {
        e.preventDefault();
        openMenu();
      });
      closeBtn.addEventListener("click", closeMenu);
      overlay.addEventListener("click", function (e) {
        if (e.target === overlay) closeMenu();
      });
      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") closeMenu();
      });
    </script>
  </body>
</html>
