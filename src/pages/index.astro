---
import MainLayout from "../layouts/MainLayout.astro";
import Stamp from "../assets/stamp.svg";
import ServicesSlider from "../assets/services-slider.webp";
import Navbar from "../components/Navbar.astro";
import { Slide } from "../components/animation/Slide.tsx";
import CTA from "../components/CTA";
import { WhatWeDoLinesMobile } from "~/home/WhatWeDoLinesMobile";
import { WhatWeDoSlider } from "~/home/WhatWeDoSlider";
import { WhatWeDoLines } from "../home/WhatWeDoLines";
import Footer from "../components/Footer.astro";
import { Image } from "astro:assets";

import heroBg from "../assets/hero-bg.webp";
import clients from "../assets/clients.webp";
import heroBgMobile from "../assets/hero-mobile.webp";
import { WhatWeSee } from "~/home/WhatWeSee";
import { Testimonials } from "~/home/Testimonials";
import { Stats } from "~/home/Stats";
import { Stages } from "~/home/Stages";
import { ReadyToBuild } from "~/home/ReadyToBuild";
---

<MainLayout head={{ title: "Kmino" }}>
  <Navbar />

  <section
    class="bg-primary relative h-dvh overflow-hidden lg:max-h-full"
    id="hero-section"
  >
    <div
      class="absolute top-1/2 left-1/2 z-20 flex h-full max-h-[632px] w-full max-w-[1242px] -translate-x-1/2 -translate-y-[45%] items-center justify-center px-4"
    >
      <div
        class="flex flex-1 flex-col items-center border-2 border-white px-4 py-10 lg:h-full lg:flex-row lg:gap-9 lg:ps-[76px] lg:pe-[36px]"
      >
        <div class="flex max-w-[594px] flex-col gap-6">
          <span
            class="text-primary hidden w-fit rounded-4xl bg-[#F4F1D2]/80 px-4 py-2 leading-[130%] lg:block"
          >
            For founders who build with AI and want it done right
          </span>

          <h1
            class="font-alt animate-hero-heading text-[28px] leading-[130%] tracking-tight text-white md:text-[48px]"
          >
            Everyone's shipping with AI. Not everyone's shipping something worth
            keeping.
          </h1>

          <p
            class="animate-hero-text max-w-xl leading-[130%] tracking-tight text-white lg:text-xl"
          >
            We're the senior technical team that makes sure your AI-assisted
            product doesn't become your biggest liability. Strategy,
            engineering, and delivery, with humans who own the outcome.
          </p>

          <div class="animate-hero-cta">
            <CTA href="https://calendar.app.google/bptKpG7DXXLZve3r5">
              Book a discovery call
            </CTA>
          </div>
        </div>

        <div
          class="mt-9 flex w-full flex-col gap-4 text-white lg:mt-20 lg:gap-10"
        >
          <div class="flex flex-col gap-2">
            <span>Trusted by</span>
            <Image src={clients} alt="Clients" />
          </div>
          <p>
            $750M+ TVL shipped · 240k users · decade of production-grade
            delivery
          </p>
        </div>
      </div>
    </div>

    <Image
      src={heroBg}
      srcset={`${heroBgMobile.src} 767w, ${heroBg.src} 1440w`}
      sizes="(max-width: 767px) 100vw, 100vw"
      alt="Hero Background"
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
      decoding="async"
    />

    <div
      class="bg-primary/50 absolute bottom-0 z-10 h-[58%] w-full backdrop-blur-lg lg:h-[42%]"
    >
    </div>

    <div id="glass-container" class="absolute inset-0"></div>
    <Image
      alt="Hero Image"
      id="glass-image"
      class="pointer-events-none absolute inset-0 h-full w-full object-cover opacity-0"
      src={heroBg}
      crossorigin="anonymous"
    />
  </section>

  <script>
    import { initGlass } from "~/utils/initGlass";

    const image = document.getElementById("glass-image");
    const glassContainer = document.getElementById("glass-container");

    if (
      image instanceof HTMLImageElement &&
      glassContainer instanceof HTMLElement
    ) {
      const shouldUseGlass = !window.matchMedia(
        "(max-width: 767px), (hover: none), (pointer: coarse)",
      ).matches;

      if (!shouldUseGlass) {
        glassContainer.remove();
      } else {
        const glassOptions = {
          distortion: 0.6,
          size: 0.4,
          speed: 0.02,
        };

        let glassInstance: ReturnType<typeof initGlass> | undefined;

        const startGlass = () => {
          if (glassInstance) return;
          if (image.naturalWidth === 0 || image.naturalHeight === 0) return;
          glassInstance = initGlass(glassContainer, { image, ...glassOptions });
        };

        if (image.complete) {
          startGlass();
        } else {
          image.addEventListener("load", startGlass, { once: true });
        }

        window.addEventListener(
          "pagehide",
          () => {
            glassInstance?.destroy();
          },
          { once: true },
        );
      }
    }
  </script>

  <WhatWeSee client:visible />

  <section
    class="relative container overflow-hidden pt-[120px] pb-[80px]"
    id="what-we-do"
  >
    <WhatWeDoLinesMobile client:media="(max-width: 768px)" />

    <Slide from="top" client:visible>
      <div class="relative z-10 mb-11 flex flex-col gap-6 text-center">
        <h1
          class="font-alt mx-auto max-w-[780px] text-[43px] leading-[1.08] tracking-tight"
        >
          Here's what you get when <br class="hidden lg:block" />
          you build with Kmino
        </h1>
        <p
          class="text-primary font-alt mx-auto max-w-[980px] text-[26px] leading-[1.25] tracking-tight"
        >
          Most agencies give you speed or quality. We built Kmino to give you
          both, because the real cost isn't the sprint, it's the rewrite.
        </p>
      </div>
    </Slide>

    <WhatWeDoLines client:media="(min-width: 1414px)" />

    <WhatWeDoSlider client:media="(max-width: 1414px)" />

    <div
      class="relative mx-auto mt-[96px] grid max-w-[1080px] grid-cols-[349px_382px_349px] justify-center -space-y-[81px] text-[22px] tracking-tight max-[1414px]:hidden"
    >
      <Stamp class="text-primary rotating absolute -top-12 -right-10 z-10" />

      <div class="col-start-1 row-start-1 self-end">
        <Slide from="left" client:visible>
          <div
            class="flex max-h-[347px] w-[349px] flex-col gap-8 bg-black px-8 py-11 text-white"
          >
            <div class="flex flex-col gap-8">
              <p
                class="text-[22px] leading-[130%] font-semibold tracking-[-0.02em]"
              >
                Senior engineering, delivered
              </p>
              <p class="text-[18px] leading-[130%] tracking-[-0.02em]">
                Fullstack, Web3, mobile, AI systems: production-grade code
                written by engineers who've shipped at scale. Clean
                architecture, real docs, you own everything.
              </p>
            </div>
            <div
              class="text-medium mt-auto flex max-w-[280px] items-center gap-3 leading-[130%] tracking-[-0.02em] text-[#F4F1D2]"
            >
              <span class="text-[24px] leading-none">✓</span>
              <span>The product gets built correctly</span>
            </div>
          </div>
        </Slide>
      </div>

      <div class="col-start-3 row-start-1 self-end">
        <Slide from="right" client:visible>
          <div
            class="ml-auto flex max-h-[347px] w-[349px] flex-col gap-8 bg-black px-8 py-11 text-white"
          >
            <div class="flex flex-col gap-8">
              <p
                class="text-[22px] leading-[130%] font-semibold tracking-[-0.02em]"
              >
                AI that works in production
              </p>
              <p class="text-[18px] leading-[130%] tracking-[-0.02em]">
                Not just demos. We integrate AI where it genuinely moves the
                needle, with audit trails, zero sensitive data sent to public
                models without approval, and human sign-off on every change.
              </p>
            </div>
            <div
              class="text-medium mt-auto flex max-w-[280px] items-center gap-3 leading-[130%] tracking-[-0.02em] text-[#F4F1D2]"
            >
              <span class="text-[24px] leading-none">✓</span>
              <span>Speed without the exposure</span>
            </div>
          </div>
        </Slide>
      </div>

      <div class="col-start-1 row-start-3 self-start">
        <Slide from="left" client:visible>
          <div
            class="flex max-h-[347px] w-[349px] flex-col gap-8 bg-black px-8 py-10 text-white"
          >
            <div class="flex flex-col gap-8">
              <p
                class="text-[22px] leading-[130%] font-semibold tracking-[-0.02em]"
              >
                Strategy before the first line of code
              </p>
              <p class="text-[18px] leading-[130%] tracking-[-0.02em]">
                We don't start building until we understand what you're building
                toward. Product vision, technical strategy, positioning: we
                pressure-test the plan so you're not paying to undo it later.
              </p>
            </div>
            <div
              class="text-medium flex max-w-[280px] items-center gap-3 leading-[130%] tracking-[-0.02em] text-[#F4F1D2]"
            >
              <span class="text-[24px] leading-none">✓</span>
              <span>Avoids the mistake hiding in your roadmap</span>
            </div>
          </div>
        </Slide>
      </div>

      <div class="col-start-2 row-start-2 flex items-start justify-center">
        <Slide from="bottom" client:visible>
          <div
            class="bg-primary flex max-h-[347px] w-[382px] flex-col gap-8 border border-black px-8 py-11 text-white"
          >
            <p
              class="text-[22px] leading-[130%] font-semibold tracking-[-0.02em]"
            >
              Yes, we use AI to write code. Here's the difference:
            </p>
            <p
              class="max-w-[285px] text-[18px] leading-[130%] tracking-[-0.02em]"
            >
              Every AI-assisted change goes through human review, automated
              tests, and architectural oversight. We use AI as a force
              multiplier, not a replacement for engineering judgment. You get
              the speed without the liability.
            </p>
          </div>
        </Slide>
      </div>

      <div class="col-start-3 row-start-3 self-start">
        <Slide from="right" client:visible>
          <div
            class="ml-auto flex max-h-[347px] w-[349px] flex-col gap-8 bg-black px-8 py-11 text-white"
          >
            <div class="flex flex-col gap-8">
              <p
                class="text-[22px] leading-[130%] font-semibold tracking-[-0.02em]"
              >
                A team aligned to outcomes, not tickets
              </p>
              <p class="text-[18px] leading-[130%] tracking-[-0.02em]">
                Playbooks, mentorship, and a culture of ownership mean you're
                not managing us, we're managing ourselves toward your goals. One
                point of contact. Full transparency. No surprises.
              </p>
            </div>
            <div
              class="text-medium mt-auto flex max-w-[280px] items-center gap-3 leading-[130%] tracking-[-0.02em] text-[#F4F1D2]"
            >
              <span class="text-[24px] leading-none">✓</span>
              <span>The rarest thing in outsourced dev</span>
            </div>
          </div>
        </Slide>
      </div>
    </div>
  </section>

  <section class="container">
    <div
      class="mx-auto flex max-w-[1120px] flex-col justify-between gap-14 lg:flex-row lg:gap-20"
    >
      <div class="max-w-[520px]">
        <h2 class="mb-6 text-[28px] leading-[1.2] tracking-tight">
          A scoped plan in 48 hours.
          <br />
          No commitment required.
        </h2>

        <CTA
          href="https://calendar.app.google/bptKpG7DXXLZve3r5"
          color="inverted"
        >
          Book your fit call
        </CTA>
      </div>

      <div class="max-w-[411px]">
        <p class="text-[22px] leading-[1.2] tracking-tight">
          Book a 30-min fit call. <br /><br />
          We review your goals, identify risks, and come back with a clear plan,
          what it takes to build it right.
        </p>
      </div>
    </div>
  </section>

  <section
    class="my-[100px] overflow-hidden lg:my-[180px]"
    aria-label="Services"
  >
    <div class="services-slider-track flex w-max items-center gap-[100px]">
      <img
        src={ServicesSlider.src}
        alt="Services"
        class="h-[101px] max-w-none shrink-0"
      />
      <img
        src={ServicesSlider.src}
        alt=""
        aria-hidden="true"
        class="h-[101px] max-w-none shrink-0"
      />
    </div>
  </section>

  <section class="flex flex-col items-center">
    <div class="font-alt mb-14 text-center lg:mb-20">
      <h2
        class="mx-auto mb-4 max-w-[358px] text-[36px] leading-[130%] tracking-tight lg:max-w-full lg:text-[43px]"
      >
        Don't take our word for it
      </h2>
      <p
        class="text-primary text-[20px] leading-[130%] tracking-tight lg:text-[26px]"
      >
        Here's what happens when AI-accelerated development is done <br />with
        craft and intention
      </p>
    </div>

    <Testimonials client:visible={{ rootMargin: "200px" }} />
  </section>

  <Stats client:visible />

  <Stages client:visible />

  <ReadyToBuild client:visible />

  <Footer />
</MainLayout>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInScale {
    from {
      opacity: 0;
      transform: scale(0.8);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes stampEntrance {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .animate-hero-heading {
    animation: fadeInUp 0.8s ease-out forwards;
    animation-delay: 0.2s;
    opacity: 0;
  }

  .animate-hero-text {
    animation: fadeInUp 0.8s ease-out forwards;
    animation-delay: 0.4s;
    opacity: 0;
  }

  .animate-hero-cta {
    animation: fadeInScale 0.6s ease-out forwards;
    animation-delay: 0.6s;
    opacity: 0;
  }

  .animate-stamp {
    animation: stampEntrance 0.8s ease-out 0.1s forwards;
    opacity: 0;
  }

  @keyframes slideInRight {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes marqueeLeft {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(calc(-50% - 50px));
    }
  }

  .animate-kmino-text {
    animation: slideInRight 1s ease-out forwards;
    animation-delay: 0.7s;
    opacity: 0;
  }

  .services-slider-track {
    animation: marqueeLeft 30s linear infinite;
    will-change: transform;
  }

  #magnetic-stamp {
    will-change: transform;
  }
</style>

<script>
  import { gsap } from "gsap";

  document.addEventListener("DOMContentLoaded", () => {
    const heroSection = document.getElementById("hero-section");
    const stamp = document.getElementById("magnetic-stamp");
    const kminoText = document.getElementById("magnetic-kmino-text");

    if (!heroSection) return;

    // Entrance animations with GSAP
    if (stamp) {
      gsap.from(stamp, {
        scale: 0.5,
        duration: 0.8,
        delay: 0.1,
        ease: "power2.out",
      });
    }

    if (kminoText) {
      gsap.from(kminoText, {
        x: 50,
        duration: 1,
        delay: 0.7,
        ease: "power2.out",
      });
    }

    const strength = 30; // Maximum pixels the elements can move

    heroSection.addEventListener("mousemove", (e) => {
      const rect = heroSection.getBoundingClientRect();
      const sectionCenterX = rect.left + rect.width / 2;
      const sectionCenterY = rect.top + rect.height / 2;

      // Calculate mouse position relative to section center (-1 to 1)
      const percentX = (e.clientX - sectionCenterX) / (rect.width / 2);
      const percentY = (e.clientY - sectionCenterY) / (rect.height / 2);

      // Move stamp based on mouse position
      if (stamp) {
        gsap.to(stamp, {
          x: percentX * strength,
          y: percentY * strength,
          duration: 0.6,
          ease: "power2.out",
        });
      }

      // Move KminoText with magnetic effect
      if (kminoText) {
        gsap.to(kminoText, {
          x: percentX * strength,
          y: percentY * strength,
          duration: 0.6,
          ease: "power2.out",
        });
      }
    });

    // Reset when mouse leaves the section
    heroSection.addEventListener("mouseleave", () => {
      if (stamp) {
        gsap.to(stamp, {
          x: 0,
          y: 0,
          duration: 0.8,
          ease: "power2.out",
        });
      }

      if (kminoText) {
        gsap.to(kminoText, {
          x: 0,
          y: 0,
          duration: 0.8,
          ease: "power2.out",
        });
      }
    });
  });
</script>
