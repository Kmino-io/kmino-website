---
import MainLayout from "../layouts/MainLayout.astro";
import TopWaves from "../assets/top-waves-mobile.svg";
import ProjectsBg from "../assets/project-bg.svg";
import Stamp from "../assets/stamp.svg";
import Navbar from "../components/Navbar.astro";
import { Slide } from "../components/animation/Slide.tsx";
import CTA from "../components/CTA";
import { WhatWeDoLinesMobile } from "~/home/WhatWeDoLinesMobile";
import { WhatWeDoSlider } from "~/home/WhatWeDoSlider";
import { HowWeWorkSlider } from "~/home/HowWeWorkSlider";
// import { Testimonials } from "~/home/Testimonials";
import { ProjectsSliderMobile } from "~/home/ProjectsSliderMobile";
import { WhatWeDoLines } from "../home/WhatWeDoLines";
import { WhyKminoLine } from "~/home/WhyKminoLine";
import { ProjectsAccordion } from "../home/ProjectsAccordion";
import { FadeIn } from "~/components/FadeIn";
import Footer from "../components/Footer.astro";
import { HowWeHelpCards } from "~/home/HowWeHelpCards";
import { FAQ } from "~/components/FAQ";
import { HowItWorksList } from "~/home/HowItWorksList";
import { AnimatedDivider } from "~/components/AnimatedDivider";
import { Image } from "astro:assets";

import heroBg from "../assets/hero-bg.webp";
---

<MainLayout head={{ title: "Kmino" }}>
  <Navbar />

  <section class="bg-primary relative h-dvh overflow-hidden" id="hero-section">
    <div
      class="absolute top-1/2 left-1/2 z-10 z-20 flex h-full max-h-[632px] w-full max-w-[1242px] -translate-x-1/2 -translate-y-[45%] flex-col justify-center border-2 border-white px-[76px]"
    >
      <h1
        class="font-alt animate-hero-heading text-[46px] leading-[130%] tracking-[-0.02em] text-white md:text-[68px]"
      >
        Velocity without <br /> compromise.
      </h1>

      <p class="animate-hero-text my-9 max-w-xl text-xl text-white">
        High-performance, distributed squads with AI-accelerated delivery and
        product advisory. Scoped plan in 48 hours. <br /><br />You own the IP,
        repos, and infra. Every merge passes human review, tests, and security
        checks.
      </p>

      <div class="animate-hero-cta">
        <CTA href="https://calendar.app.google/bptKpG7DXXLZve3r5">
          Book a discovery call
        </CTA>
      </div>
    </div>

    <div id="hero-parallax" class="absolute inset-0 overflow-hidden">
      <Image
        src={heroBg}
        alt="Hero Background"
        id="hero-parallax-back"
        class="absolute inset-0 h-full w-full object-cover"
      />

      <Image
        src={heroBg}
        alt=""
        aria-hidden="true"
        id="hero-parallax-front"
        class="absolute inset-0 h-full w-full object-cover opacity-35 blur-[2px]"
      />
    </div>

    <div
      class="bg-primary/50 absolute bottom-0 z-10 h-[40%] w-full backdrop-blur-lg"
    >
    </div>
  </section>

  <script>
    const heroSection = document.getElementById("hero-section");
    const backLayer = document.getElementById("hero-parallax-back");
    const frontLayer = document.getElementById("hero-parallax-front");
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    if (
      heroSection instanceof HTMLElement &&
      backLayer instanceof HTMLElement &&
      frontLayer instanceof HTMLElement &&
      !prefersReducedMotion
    ) {
      const scale = {
        back: 1.08,
        front: 1.14,
      };
      const strength = {
        back: 14,
        front: -28,
      };
      const smoothing = 0.03;
      const epsilon = 0.001;

      let targetX = 0;
      let targetY = 0;
      let currentX = 0;
      let currentY = 0;
      let rafId = 0;
      let isAnimating = false;

      backLayer.style.transform = `translate3d(0, 0, 0) scale(${scale.back})`;
      frontLayer.style.transform = `translate3d(0, 0, 0) scale(${scale.front})`;

      const startAnimation = () => {
        if (isAnimating) return;
        isAnimating = true;
        rafId = requestAnimationFrame(applyTransform);
      };

      const applyTransform = () => {
        currentX += (targetX - currentX) * smoothing;
        currentY += (targetY - currentY) * smoothing;

        backLayer.style.transform = `translate3d(${currentX * strength.back}px, ${currentY * strength.back}px, 0) scale(${scale.back})`;
        frontLayer.style.transform = `translate3d(${currentX * strength.front}px, ${currentY * strength.front}px, 0) scale(${scale.front})`;

        if (
          Math.abs(targetX - currentX) < epsilon &&
          Math.abs(targetY - currentY) < epsilon
        ) {
          isAnimating = false;
          return;
        }

        rafId = requestAnimationFrame(applyTransform);
      };

      const handleMouseMove = (event: MouseEvent) => {
        const rect = heroSection.getBoundingClientRect();
        const normalizedX = (event.clientX - rect.left) / rect.width;
        const normalizedY = (event.clientY - rect.top) / rect.height;

        targetX = (normalizedX - 0.5) * 2;
        targetY = (normalizedY - 0.5) * 2;
        startAnimation();
      };

      const resetParallax = () => {
        targetX = 0;
        targetY = 0;
        startAnimation();
      };

      heroSection.addEventListener("mousemove", handleMouseMove);
      heroSection.addEventListener("mouseleave", resetParallax);

      window.addEventListener(
        "pagehide",
        () => {
          if (rafId) cancelAnimationFrame(rafId);
          heroSection.removeEventListener("mousemove", handleMouseMove);
          heroSection.removeEventListener("mouseleave", resetParallax);
        },
        { once: true },
      );
    }
  </script>

  <section
    class="relative container overflow-hidden pt-[120px] pb-[100px] lg:mb-[200px]"
    id="what-we-do"
  >
    <WhatWeDoLinesMobile client:media="(max-width: 768px)" />

    <Slide from="top" client:visible>
      <div class="relative z-10 mb-11 flex flex-col gap-6">
        <h1 class="heading">What we Do</h1>
        <p class="subheading text-primary mx-auto max-w-[341px]">
          We help product leaders and founders move faster with:
        </p>
      </div>
    </Slide>

    <WhatWeDoLines client:media="(min-width: 1414px)" />

    <WhatWeDoSlider client:media="(max-width: 1414px)" />

    <div
      class="relative mx-auto mt-[79px] flex min-h-[856px] max-w-[1080px] justify-between text-[22px] tracking-tight max-[1414px]:hidden"
    >
      <Stamp class="text-primary rotating absolute -top-12 -right-10 z-10" />

      <div class="flex flex-col justify-between">
        <Slide from="left" client:visible>
          <div
            class="flex min-h-[347px] max-w-[349px] flex-col justify-center gap-4 bg-black px-[26px] text-white"
          >
            <p class="font-semibold">Fullstack Web & Mobile Development</p>
            <p>
              TypeScript/Node, React/React Native, modern APIs. Predictable
              delivery, clean architecture, clear docs.
            </p>
          </div>
        </Slide>

        <Slide from="left" client:visible>
          <div
            class="flex min-h-[347px] max-w-[349px] flex-col justify-center gap-4 bg-black px-[26px] text-white"
          >
            <p class="font-semibold">Staff Augmentation</p>
            <p>
              Embedded engineers who ship from week one. Immediate velocity
              without microman micromanImmediate velocity withoutagement.
            </p>
          </div>
        </Slide>
      </div>

      <div class="flex items-center">
        <Slide from="bottom" client:visible>
          <div
            class="bg-primary flex min-h-[347px] max-w-[382px] flex-col justify-center gap-4 border border-black px-[26px] text-white"
          >
            <p class="font-semibold">Web3 & Smart Contract Development</p>
            <p>
              Auditable contracts, gas‑aware design, test‑first workflows.
              Security and upgrade paths you can trust.
            </p>
          </div>
        </Slide>
      </div>

      <div class="flex flex-col justify-between">
        <Slide from="right" client:visible>
          <div
            class="flex min-h-[347px] max-w-[349px] flex-col justify-center gap-4 bg-black px-[26px] text-white"
          >
            <p class="font-semibold">Product & Delivery Advisory</p>
            <p>
              Beyond tech. We help you refine your product vision, sharpen your
              positioning, craft a compelling brand, and even connect with
              investors: everything you need to build with purpose and raise
              with confidence.
            </p>
          </div>
        </Slide>

        <Slide from="right" client:visible>
          <div
            class="flex min-h-[347px] max-w-[349px] flex-col justify-center gap-4 bg-black px-[26px] text-white"
          >
            <p class="font-semibold">AI development</p>
            <p>
              Custom LLMs, RAG systems, intelligent automation. AI that actually
              works in production, not just demos.
            </p>
          </div>
        </Slide>
      </div>
    </div>
  </section>

  <section class="relative flex flex-col items-end overflow-hidden py-24">
    <WhyKminoLine client:media="(min-width: 1024px)" />

    <div class="container flex max-w-[1000px] lg:justify-end">
      <div class="w-fit space-y-11 lg:max-w-[381px]">
        <h1 class="heading text-left">Why Kmino?</h1>

        <div class="flex flex-col gap-4 text-xl tracking-tight lg:gap-8">
          <p>
            <strong>Elite Tech Teams, AI-Accelerated</strong><br />Small,
            high-performance squads that integrate fast, ship reliably, and stay
            aligned to your goals.
          </p>
          <p>
            <strong>Built-In Excellence</strong><br />Playbooks, mentorship, and
            weekly training are baked into every sprint.
          </p>
          <p>
            <strong>Own Everything</strong><br />Your code, your infra—clean
            docs and smooth handovers guaranteed.
          </p>
          <p>If you want dependable, maintainable velocity—we should talk.</p>
        </div>
      </div>
    </div>

    <Stamp class="text-primary rotating ml-auto lg:hidden" />
  </section>

  <section
    class="container mt-[70px] mb-[120px] overflow-hidden lg:mt-[200px]"
    id="how-we-work"
  >
    <div class="relative mb-11 md:mb-[100px]">
      <h1 class="heading text-left">How we Work</h1>
      <p class="subheading text-primary max-w-[341px] text-left">
        Our Process. Your Advantage.
      </p>

      <Stamp
        class="text-primary rotating absolute top-0 right-0 hidden lg:block"
      />
    </div>

    <HowWeWorkSlider client:visible={{ rootMargin: "500px" }} />
  </section>

  <!-- <section
    class="container my-[100px] flex flex-col items-center lg:my-[200px]"
  >
    <Testimonials client:visible={{ rootMargin: "200px" }} />
  </section> -->

  <section
    class="relative container my-[100px] mt-0 overflow-hidden lg:my-[200px]"
    id="projects"
  >
    <FadeIn
      client:visible
      className="flex w-full flex-col items-center lg:items-start"
    >
      <h1 class="heading mb-6 text-left">Trusted by Innovators Worldwide</h1>

      <p class="subheading text-primary mb-6 text-left lg:mb-14">
        We’ve helped startups and protocols scale their products, faster
      </p>

      <ProjectsSliderMobile
        client:media="(max-width: 1079px)"
        client:visible={{ rootMargin: "800px" }}
      />

      <ProjectsAccordion
        client:media="(min-width: 1080px)"
        client:visible={{ rootMargin: "500px" }}
      />

      <ProjectsBg class="absolute -top-3 -z-10 lg:hidden" />
    </FadeIn>
  </section>

  <AnimatedDivider client:media="(min-width: 768px)" />

  <section class="relative mt-[100px] mb-[100px] lg:mt-[200px] lg:mb-[200px]">
    <div class="mx-auto max-w-[1080px] px-4 xl:px-0">
      <div class="mb-[60px] space-y-6">
        <h1 class="heading">How KMINO can help you</h1>
        <p class="subheading text-primary mx-auto max-w-[771px] text-center">
          We have 3 basic engagement models, and are always open to discuss what
          works for your project - you choose the best path.
        </p>
      </div>

      <HowWeHelpCards client:visible={{ rootMargin: "300px" }} />

      <div
        class="my-[60px] flex w-full flex-col items-start justify-between gap-6 lg:flex-row lg:items-center"
      >
        <h1 class="heading lg:mb-32">How it Works:</h1>
        <HowItWorksList client:visible={{ rootMargin: "600px" }} />
      </div>

      <CTA
        href="https://calendar.app.google/bptKpG7DXXLZve3r5"
        color="inverted"
        className="mx-auto"
      >
        Book a discovery call
      </CTA>
    </div>
  </section>

  <TopWaves class="text-primary relative z-50" />



  <TopWaves class="relative z-50 text-black" />

  <section
    class="relative z-50 -mt-1 bg-black pb-32 text-2xl text-white"
    id="about-us"
  >
    <Stamp class="rotating text-primary absolute right-12" />

    <div class="relative container max-w-[942px] pt-[100px]">
      <h1 class="heading relative z-10 mb-[73px] text-left lg:mb-[68px]">
        Ethical and Secure AI
      </h1>

      <FadeIn client:visible>
        <div class="flex flex-col gap-8 tracking-tighter">
          <p>
            We use AI to accelerate delivery, not to replace engineering
            judgment.
          </p>

          <p>
            No customer code or sensitive data is sent to public models without
            written approval.
          </p>

          <p>We prefer self‑hosted or enterprise tools with audit logs.</p>

          <p>
            Every AI‑assisted change passes human review, automated tests, and
            security checks.
          </p>
        </div>
      </FadeIn>
    </div>
  </section>

  <section class="relative z-50 bg-white py-16 lg:py-[200px]">
    <div
      class="mx-auto flex max-w-[1080px] flex-col items-start gap-0 px-4 md:gap-[68px] xl:px-0"
    >
      <h1 class="heading">FAQ</h1>

      <FAQ
        faqs={[
          {
            number: "01",
            question: "Where are you based?",
            answer:
              "We’re distributed. You get dependable overlap with your core hours and a single point of contact.",
          },
          {
            number: "02",
            question: "How do you keep quality high if you move fast?",
            answer:
              "Gatekeeping via tests, static analysis, and reviews; strict Definition of Done; weekly retros and playbook updates.",
          },
          {
            number: "03",
            question: "Will we be locked in?",
            answer:
              "No. You own the repo, infra, CI, and docs. We train your team before exit if desired.",
          },
          {
            number: "04",
            question: "Do you work with regulated teams?",
            answer:
              "Yes. We align with SOC 2, GDPR, and security reviews. We avoid public model exposure without consent.",
          },
          {
            number: "05",
            question: "What’s the fastest way to start?",
            answer:
              "Share your roadmap. We’ll propose a pilot or 6‑week plan within 48 hours.",
          },
        ]}
        client:visible
      />
    </div>
  </section>

  <Footer />
</MainLayout>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInScale {
    from {
      opacity: 0;
      transform: scale(0.8);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .animate-hero-heading {
    animation: fadeInUp 0.8s ease-out forwards;
    animation-delay: 0.2s;
    opacity: 0;
  }

  .animate-hero-text {
    animation: fadeInUp 0.8s ease-out forwards;
    animation-delay: 0.4s;
    opacity: 0;
  }

  .animate-hero-cta {
    animation: fadeInScale 0.6s ease-out forwards;
    animation-delay: 0.6s;
    opacity: 0;
  }

  #hero-parallax-back,
  #hero-parallax-front {
    will-change: transform;
  }
</style>
